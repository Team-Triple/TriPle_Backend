<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- 스프링 기본 로그 -->
    <appender name="ROOT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- 디버깅 로그 -->
    <appender name="DEBUG" class="ch.qos.logback.core.ConsoleAppender">
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>DEBUG</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <encoder>
            <pattern>%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} %-5level %X{traceId} method = %X{method:none} path=%X{path:none} msg="%msg" "latency"="%X{latency:progressing}"%n%ex</pattern>
        </encoder>
    </appender>

    <!-- 어플리케이션 로그 -->
    <appender name="APPLICATION" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>
                {"traceId":"%X{traceId:-}", "timestamp":"%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX}", "level":"%-5level", "method":"%X{method:none}", "path":"%X{path:none}", "msg":"%msg", "latency":"%X{latency:progressing}", "exception":"%ex"}%n
            </pattern>
        </encoder>
    </appender>

    <!-- 개발 서버 로그 설정 -->
    <springProfile name="dev">
        <logger name="org.triple.backend" level="DEBUG" additivity="false">
            <appender-ref ref="DEBUG"/>
            <appender-ref ref="APPLICATION"/>
        </logger>
        <logger name="org.hibernate.SQL" level="DEBUG"/>
        <root level="INFO">
            <appender-ref ref="ROOT"/>
        </root>
    </springProfile>

    <!-- 운영 서버 로그 설정 -->
    <springProfile name="prod">
        <logger name="org.triple.backend" level="INFO" additivity="true">
            <appender-ref ref="APPLICATION"/>
        </logger>
        <logger name="org.hibernate.SQL" level="WARN"/>
        <root level="INFO">
            <appender-ref ref="ROOT"/>
        </root>
    </springProfile>

    <!-- 로컬 로그 설정 -->
    <springProfile name="local">
        <logger name="org.triple.backend" level="DEBUG" additivity="true">
            <appender-ref ref="DEBUG"/>
            <appender-ref ref="APPLICATION"/>
        </logger>
        <logger name="org.hibernate.SQL" level="DEBUG"/>
        <root level="INFO">
            <appender-ref ref="ROOT"/>
        </root>
    </springProfile>

    <springProfile name="!dev &amp; !prod &amp; !local">
        <root level="INFO">
            <appender-ref ref="ROOT"/>
        </root>
    </springProfile>
</configuration>
